{
  "name": "ui-library-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo --open --port 58790",
    "demo": "ng serve demo --open --port 58790",
    "start:v4": "cd projects/demo-v4 && ng serve",
    "demo:v4": "cd projects/demo-v4 && ng serve --open --port 58791",
    "install:v4": "cd projects/demo-v4 && npm install",
    "build": "node scripts/build-pdfium-worker.mjs && ng build @hakistack/ng-daisyui && node scripts/fix-exports.mjs && node scripts/build-schematics.mjs && node scripts/extract-fesm-classes.mjs",
    "build:i18n": "ng build @hakistack/i18n && node scripts/build-i18n-cli.mjs && node scripts/build-i18n-schematics.mjs",
    "vercel:build": "ng build demo --base-href=/ && npm --prefix projects/demo-v4 run build -- --base-href=/v4/ && node scripts/assemble-vercel.mjs",
    "lint": "ng lint",
    "build:watch": "ng build @hakistack/ng-daisyui --watch",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --configuration=coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "publish:local": "cd dist/hakistack/ng-daisyui && npm link",
    "publish:registry": "cp .npmrc dist/hakistack/ng-daisyui/.npmrc && cd dist/hakistack/ng-daisyui && npm publish",
    "publish:i18n:registry": "cp .npmrc dist/hakistack/i18n/.npmrc && cd dist/hakistack/i18n && npm publish",
    "release:patch": "node scripts/release.mjs patch && npm run build",
    "release:minor": "node scripts/release.mjs minor && npm run build",
    "release:major": "node scripts/release.mjs major && npm run build",
    "size": "size-limit",
    "size:check": "size-limit --json",
    "extract-api-docs": "node scripts/extract-api-docs.mjs",
    "engine:check": "cargo check --manifest-path hakistack-engine/Cargo.toml --workspace --all-targets",
    "engine:test": "cargo test --manifest-path hakistack-engine/Cargo.toml --workspace",
    "pdfium:fetch": "node scripts/fetch-pdfium.mjs",
    "engine:build": "node scripts/build-wasm.mjs",
    "engine:build:dev": "node scripts/build-wasm.mjs --dev",
    "engine:clean": "cargo clean --manifest-path hakistack-engine/Cargo.toml && rm -rf hakistack-engine/pkg projects/hakistack/ng-daisyui/src/lib/wasm",
    "libheif:build": "bash hakistack-engine/external/libheif-wasm/build.sh",
    "libheif:build:dev": "LIBHEIF_BUILD_PROFILE=dev bash hakistack-engine/external/libheif-wasm/build.sh",
    "libheif:clean": "rm -rf hakistack-engine/external/libheif-wasm/build hakistack-engine/external/libheif-wasm/vendor projects/hakistack/ng-daisyui/src/lib/wasm/libheif",
    "prepare": "husky"
  },
  "size-limit": [
    {
      "path": "dist/hakistack/ng-daisyui/fesm2022/hakistack-ng-daisyui.mjs",
      "limit": "250 kB",
      "gzip": true,
      "name": "Library bundle (fesm2022, gzip)"
    },
    {
      "path": "dist/hakistack/ng-daisyui/fesm2022/hakistack-ng-daisyui.mjs",
      "limit": "180 kB",
      "name": "Library bundle (fesm2022, brotli)"
    }
  ],
  "prettier": {
    "printWidth": 140,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "lint-staged": {
    "*.{ts,html}": [
      "prettier --write"
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.3",
  "dependencies": {
    "@angular/animations": "^21.2.10",
    "@angular/aria": "^21.2.9",
    "@angular/cdk": "^21.2.9",
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/forms": "^21.2.10",
    "@angular/platform-browser": "^21.2.10",
    "@angular/router": "^21.2.10",
    "@jsverse/transloco": "^8.2.1",
    "@kenjiuno/msgreader": "^1.28.0",
    "@lucide/angular": "^1.7.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tiptap/suggestion": "^3.22.4",
    "docx-preview": "^0.3.7",
    "dompurify": "^3.4.8",
    "foliate-js": "^1.0.1",
    "fuse.js": "^7.2.0",
    "heic2any": "^0.0.4",
    "libphonenumber-js": "^1.12.42",
    "motion": "^12.38.0",
    "postal-mime": "^2.7.4",
    "postcss": "^8.5.8",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.10",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-file-handler": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-istanbul": "^4.1.2",
    "angular-eslint": "^21.3.1",
    "buffer": "^6.0.3",
    "daisyui": "^5.5.19",
    "eslint": "^10.2.0",
    "events": "^3.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "ng-packagr": "^21.2.2",
    "prettier": "^3.8.1",
    "shiki": "^4.0.2",
    "size-limit": "^12.0.1",
    "tailwindcss": "^4.2.2",
    "ts-morph": "^28.0.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.0.8"
  }
}
