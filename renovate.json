{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "groupName": "angular",
      "matchPackagePatterns": ["^@angular/"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "groupName": "tailwind",
      "matchPackagePatterns": ["^@tailwindcss/", "^tailwindcss$", "^daisyui$"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "groupName": "testing",
      "matchPackageNames": ["vitest", "jsdom", "@playwright/test"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "groupName": "linting",
      "matchPackagePatterns": ["eslint", "@angular-eslint", "@typescript-eslint"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major"]
    }
  ],
  "schedule": ["before 9am on monday"]
}
