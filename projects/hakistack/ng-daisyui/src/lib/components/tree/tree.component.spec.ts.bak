import { ComponentFixture, TestBed } from '@angular/core/testing';

import { TreeComponent } from './tree.component';
import { TreeNode } from '../../api/treenode';
import { TreeConfig } from './tree.types';
import {
  createTree,
  node,
  walkTree,
  findNode,
  findNodePath,
  mapTree,
  filterTree,
  flattenTree,
  countNodes,
  ensureKeys,
  buildTree,
} from './tree.helpers';

// ---------------------------------------------------------------------------
// Test data factories
// ---------------------------------------------------------------------------

function makeSimpleTree(): TreeNode[] {
  return [
    {
      key: 'root-1',
      label: 'Documents',
      children: [
        { key: 'doc-1', label: 'Resume.pdf', leaf: true },
        { key: 'doc-2', label: 'Cover Letter.docx', leaf: true },
      ],
    },
    {
      key: 'root-2',
      label: 'Pictures',
      children: [
        { key: 'pic-1', label: 'Vacation.jpg', leaf: true },
        {
          key: 'pic-2',
          label: 'Screenshots',
          children: [
            { key: 'ss-1', label: 'Bug Report.png', leaf: true },
          ],
        },
      ],
    },
    { key: 'root-3', label: 'README.md', leaf: true },
  ];
}

function makeExpandedTree(): TreeNode[] {
  return [
    {
      key: 'root-1',
      label: 'Documents',
      expanded: true,
      children: [
        { key: 'doc-1', label: 'Resume.pdf', leaf: true },
        { key: 'doc-2', label: 'Cover Letter.docx', leaf: true },
      ],
    },
  ];
}

// ---------------------------------------------------------------------------
// Helper function tests
// ---------------------------------------------------------------------------

describe('Tree helpers', () => {
  describe('createTree', () => {
    it('should split nodes from config', () => {
      const result = createTree({
        nodes: [{ key: 'a', label: 'A' }],
        filterable: true,
        showLines: true,
      });

      expect(result.nodes).toHaveLength(1);
      expect(result.nodes[0].label).toBe('A');
      expect(result.config.filterable).toBe(true);
      expect(result.config.showLines).toBe(true);
    });

    it('should provide sensible defaults for config', () => {
      const result = createTree({ nodes: [] });

      expect(result.config.selectionMode).toBeNull();
      expect(result.config.dragDrop).toBe(false);
      expect(result.config.filterable).toBe(false);
      expect(result.config.filterMode).toBe('lenient');
      expect(result.config.indentSize).toBe(24);
      expect(result.config.propagateSelectionDown).toBe(true);
      expect(result.config.propagateSelectionUp).toBe(true);
      expect(result.config.expandAll).toBe(false);
      expect(result.config.keyboardNavigation).toBe(true);
      expect(result.config.emptyMessage).toBe('No data available');
    });

    it('should ensure keys are assigned to nodes without keys', () => {
      const result = createTree({
        nodes: [{ label: 'No Key' }],
      });

      expect(result.nodes[0].key).toBeTruthy();
    });
  });

  describe('node builders', () => {
    it('node.create should create a generic node with a key', () => {
      const n = node.create('Test');
      expect(n.label).toBe('Test');
      expect(n.key).toBeTruthy();
    });

    it('node.create should accept overrides', () => {
      const n = node.create('Test', { icon: 'Search', selectable: false });
      expect(n.label).toBe('Test');
      expect(n.icon).toBe('Search');
      expect(n.selectable).toBe(false);
    });

    it('node.folder should create a folder node with children', () => {
      const child = node.file('child.txt');
      const folder = node.folder('MyFolder', [child]);

      expect(folder.label).toBe('MyFolder');
      expect(folder.icon).toBe('Folder');
      expect(folder.expandedIcon).toBe('FolderOpen');
      expect(folder.children).toHaveLength(1);
      expect(folder.children![0]).toBe(child);
    });

    it('node.file should create a leaf node', () => {
      const f = node.file('readme.md');
      expect(f.label).toBe('readme.md');
      expect(f.leaf).toBe(true);
      expect(f.key).toBeTruthy();
    });

    it('node.lazy should create a lazy-loading node', () => {
      const lazy = node.lazy('Archives');
      expect(lazy.label).toBe('Archives');
      expect(lazy.leaf).toBe(false);
      expect(lazy.children).toBeUndefined();
      expect(lazy.icon).toBe('Folder');
    });

    it('node.fromData should convert flat data to TreeNode[]', () => {
      interface Dept {
        name: string;
        subs?: Dept[];
      }

      const data: Dept[] = [
        {
          name: 'Engineering',
          subs: [{ name: 'Frontend' }, { name: 'Backend' }],
        },
        { name: 'Marketing' },
      ];

      const result = node.fromData(data, {
        labelFn: (d) => d.name,
        childrenFn: (d) => d.subs,
      });

      expect(result).toHaveLength(2);
      expect(result[0].label).toBe('Engineering');
      expect(result[0].children).toHaveLength(2);
      expect(result[0].children![0].label).toBe('Frontend');
      expect(result[1].label).toBe('Marketing');
      expect(result[1].leaf).toBe(true);
    });

    it('node.fromData should attach original data to node.data', () => {
      const items = [{ id: '1', title: 'Item 1' }];
      const result = node.fromData(items, {
        labelFn: (i) => i.title,
        keyFn: (i) => i.id,
      });

      expect(result[0].data).toBe(items[0]);
      expect(result[0].key).toBe('1');
    });
  });

  describe('walkTree', () => {
    it('should visit all nodes depth-first', () => {
      const nodes = makeSimpleTree();
      const visited: string[] = [];

      walkTree(nodes, (n) => {
        visited.push(n.label!);
      });

      expect(visited).toEqual([
        'Documents',
        'Resume.pdf',
        'Cover Letter.docx',
        'Pictures',
        'Vacation.jpg',
        'Screenshots',
        'Bug Report.png',
        'README.md',
      ]);
    });

    it('should pass parent to callback', () => {
      const nodes = makeSimpleTree();
      const pairs: Array<[string, string | null]> = [];

      walkTree(nodes, (n, parent) => {
        pairs.push([n.label!, parent?.label ?? null]);
      });

      expect(pairs[0]).toEqual(['Documents', null]);
      expect(pairs[1]).toEqual(['Resume.pdf', 'Documents']);
      expect(pairs[6]).toEqual(['Bug Report.png', 'Screenshots']);
    });

    it('should stop traversal when callback returns false', () => {
      const nodes = makeSimpleTree();
      const visited: string[] = [];

      walkTree(nodes, (n) => {
        visited.push(n.label!);
        if (n.key === 'doc-2') return false;
        return undefined;
      });

      expect(visited).toEqual(['Documents', 'Resume.pdf', 'Cover Letter.docx']);
    });
  });

  describe('findNode', () => {
    it('should find a node by predicate', () => {
      const nodes = makeSimpleTree();
      const found = findNode(nodes, (n) => n.key === 'pic-1');

      expect(found).toBeTruthy();
      expect(found!.label).toBe('Vacation.jpg');
    });

    it('should find a deeply nested node', () => {
      const nodes = makeSimpleTree();
      const found = findNode(nodes, (n) => n.key === 'ss-1');

      expect(found).toBeTruthy();
      expect(found!.label).toBe('Bug Report.png');
    });

    it('should return undefined when not found', () => {
      const nodes = makeSimpleTree();
      const found = findNode(nodes, (n) => n.key === 'nonexistent');

      expect(found).toBeUndefined();
    });

    it('should return the first match', () => {
      const nodes: TreeNode[] = [
        { key: 'a', label: 'Match', data: 1 },
        { key: 'b', label: 'Match', data: 2 },
      ];

      const found = findNode(nodes, (n) => n.label === 'Match');
      expect(found!.data).toBe(1);
    });
  });

  describe('findNodePath', () => {
    it('should return the ancestor path to a node', () => {
      const nodes = makeSimpleTree();
      const path = findNodePath(nodes, (n) => n.key === 'ss-1');

      expect(path).toBeTruthy();
      expect(path!.map((n) => n.label)).toEqual(['Pictures', 'Screenshots', 'Bug Report.png']);
    });

    it('should return single-element path for root node', () => {
      const nodes = makeSimpleTree();
      const path = findNodePath(nodes, (n) => n.key === 'root-1');

      expect(path).toEqual([nodes[0]]);
    });

    it('should return undefined when node not found', () => {
      const nodes = makeSimpleTree();
      const path = findNodePath(nodes, (n) => n.key === 'nonexistent');

      expect(path).toBeUndefined();
    });
  });

  describe('mapTree', () => {
    it('should transform every node', () => {
      const nodes: TreeNode[] = [
        { key: 'a', label: 'A', children: [{ key: 'b', label: 'B' }] },
      ];

      const mapped = mapTree(nodes, (n) => ({ ...n, label: n.label + '!' }));

      expect(mapped[0].label).toBe('A!');
      expect(mapped[0].children![0].label).toBe('B!');
    });

    it('should not mutate original nodes', () => {
      const nodes: TreeNode[] = [{ key: 'a', label: 'A' }];
      mapTree(nodes, (n) => ({ ...n, label: 'changed' }));

      expect(nodes[0].label).toBe('A');
    });
  });

  describe('filterTree', () => {
    it('should keep only matching nodes and their ancestors', () => {
      const nodes = makeSimpleTree();
      const filtered = filterTree(nodes, (n) => n.key === 'ss-1');

      // Should preserve: Pictures > Screenshots > Bug Report.png
      expect(filtered).toHaveLength(1);
      expect(filtered[0].label).toBe('Pictures');
      expect(filtered[0].children).toHaveLength(1);
      expect(filtered[0].children![0].label).toBe('Screenshots');
      expect(filtered[0].children![0].children).toHaveLength(1);
      expect(filtered[0].children![0].children![0].label).toBe('Bug Report.png');
    });

    it('should return empty array when no matches', () => {
      const nodes = makeSimpleTree();
      const filtered = filterTree(nodes, () => false);

      expect(filtered).toHaveLength(0);
    });
  });

  describe('flattenTree', () => {
    it('should flatten to a single array in DFS order', () => {
      const nodes = makeSimpleTree();
      const flat = flattenTree(nodes);

      expect(flat).toHaveLength(8);
      expect(flat[0].label).toBe('Documents');
      expect(flat[7].label).toBe('README.md');
    });
  });

  describe('countNodes', () => {
    it('should count all nodes recursively', () => {
      const nodes = makeSimpleTree();
      expect(countNodes(nodes)).toBe(8);
    });

    it('should return 0 for empty array', () => {
      expect(countNodes([])).toBe(0);
    });
  });

  describe('ensureKeys', () => {
    it('should assign keys to nodes without them', () => {
      const nodes: TreeNode[] = [
        { label: 'A', children: [{ label: 'B' }] },
      ];

      ensureKeys(nodes);

      expect(nodes[0].key).toBeTruthy();
      expect(nodes[0].children![0].key).toBeTruthy();
    });

    it('should not overwrite existing keys', () => {
      const nodes: TreeNode[] = [{ key: 'my-key', label: 'A' }];

      ensureKeys(nodes);

      expect(nodes[0].key).toBe('my-key');
    });

    it('should support an optional prefix', () => {
      const nodes: TreeNode[] = [{ label: 'A' }];

      ensureKeys(nodes, 'prefix');

      expect(nodes[0].key!.startsWith('prefix-')).toBe(true);
    });
  });

  describe('buildTree', () => {
    it('should build a tree from a flat list with parent IDs', () => {
      const items = [
        { id: '1', parentId: null, name: 'CEO' },
        { id: '2', parentId: '1', name: 'CTO' },
        { id: '3', parentId: '1', name: 'CFO' },
        { id: '4', parentId: '2', name: 'Dev Lead' },
      ];

      const tree = buildTree(items, {
        idFn: (i) => i.id,
        parentIdFn: (i) => i.parentId,
        labelFn: (i) => i.name,
      });

      expect(tree).toHaveLength(1);
      expect(tree[0].label).toBe('CEO');
      expect(tree[0].children).toHaveLength(2);
      expect(tree[0].children![0].label).toBe('CTO');
      expect(tree[0].children![0].children).toHaveLength(1);
      expect(tree[0].children![0].children![0].label).toBe('Dev Lead');
      // CFO is a leaf
      expect(tree[0].children![1].label).toBe('CFO');
      expect(tree[0].children![1].leaf).toBe(true);
    });

    it('should mark childless nodes as leaf', () => {
      const items = [{ id: '1', parentId: null, name: 'Solo' }];
      const tree = buildTree(items, {
        idFn: (i) => i.id,
        parentIdFn: (i) => i.parentId,
        labelFn: (i) => i.name,
      });

      expect(tree[0].leaf).toBe(true);
      expect(tree[0].children).toBeUndefined();
    });

    it('should handle multiple roots', () => {
      const items = [
        { id: '1', parentId: null, name: 'Root A' },
        { id: '2', parentId: null, name: 'Root B' },
      ];

      const tree = buildTree(items, {
        idFn: (i) => i.id,
        parentIdFn: (i) => i.parentId,
        labelFn: (i) => i.name,
      });

      expect(tree).toHaveLength(2);
    });

    it('should attach original data to node.data', () => {
      const items = [{ id: '1', parentId: null, name: 'Root', extra: 42 }];
      const tree = buildTree(items, {
        idFn: (i) => i.id,
        parentIdFn: (i) => i.parentId,
        labelFn: (i) => i.name,
      });

      expect(tree[0].data).toBe(items[0]);
    });
  });
});

// ---------------------------------------------------------------------------
// TreeComponent tests
// ---------------------------------------------------------------------------

describe('TreeComponent', () => {
  let component: TreeComponent;
  let fixture: ComponentFixture<TreeComponent>;

  beforeEach(async () => {
    await TestBed.configureTestingModule({
      imports: [TreeComponent],
    }).compileComponents();

    fixture = TestBed.createComponent(TreeComponent);
    component = fixture.componentInstance;
  });

  it('should create', () => {
    fixture.detectChanges();
    expect(component).toBeTruthy();
  });

  // -------------------------------------------------------------------------
  // Rendering
  // -------------------------------------------------------------------------

  describe('rendering', () => {
    it('should show empty message when no nodes provided', () => {
      fixture.detectChanges();
      const el: HTMLElement = fixture.nativeElement;
      expect(el.textContent).toContain('No data available');
    });

    it('should show custom empty message from config', () => {
      fixture.componentRef.setInput('config', { emptyMessage: 'Nothing here' } as TreeConfig);
      fixture.detectChanges();
      const el: HTMLElement = fixture.nativeElement;
      expect(el.textContent).toContain('Nothing here');
    });

    it('should render root node labels', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      expect(el.textContent).toContain('Documents');
      expect(el.textContent).toContain('Pictures');
      expect(el.textContent).toContain('README.md');
    });

    it('should not render children of collapsed nodes', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      // Children should not be visible since nodes are collapsed by default
      expect(el.textContent).not.toContain('Resume.pdf');
    });

    it('should render children of initially expanded nodes', () => {
      const nodes = makeExpandedTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      expect(el.textContent).toContain('Documents');
      expect(el.textContent).toContain('Resume.pdf');
      expect(el.textContent).toContain('Cover Letter.docx');
    });

    it('should show loading spinner when loading is true', () => {
      fixture.componentRef.setInput('config', { loading: true } as TreeConfig);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      const spinner = el.querySelector('.loading-spinner');
      expect(spinner).toBeTruthy();
    });

    it('should set role="tree" on host', () => {
      fixture.detectChanges();
      const el: HTMLElement = fixture.nativeElement;
      expect(el.getAttribute('role')).toBe('tree');
    });

    it('should render treeitem roles for each node', () => {
      const nodes = makeExpandedTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      const treeItems = el.querySelectorAll('[role="treeitem"]');
      // Documents (expanded) + Resume.pdf + Cover Letter.docx = 3
      expect(treeItems.length).toBe(3);
    });
  });

  // -------------------------------------------------------------------------
  // Tree input (createTree)
  // -------------------------------------------------------------------------

  describe('tree input (createTree)', () => {
    it('should accept a TreeSetup from createTree', () => {
      const tree = createTree({
        nodes: [{ key: 'a', label: 'Alpha' }],
        filterable: true,
      });

      fixture.componentRef.setInput('tree', tree);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      expect(el.textContent).toContain('Alpha');
    });

    it('should prefer tree input over nodes input', () => {
      const tree = createTree({ nodes: [{ key: 'a', label: 'From Tree' }] });

      fixture.componentRef.setInput('tree', tree);
      fixture.componentRef.setInput('nodes', [{ key: 'b', label: 'From Nodes' }]);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      expect(el.textContent).toContain('From Tree');
      expect(el.textContent).not.toContain('From Nodes');
    });
  });

  // -------------------------------------------------------------------------
  // Expand / Collapse
  // -------------------------------------------------------------------------

  describe('expand and collapse', () => {
    it('should expand a node programmatically', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      component.expandNode(nodes[0]);
      fixture.detectChanges();

      expect(component.isExpanded(nodes[0])).toBe(true);
      const el: HTMLElement = fixture.nativeElement;
      expect(el.textContent).toContain('Resume.pdf');
    });

    it('should collapse an expanded node programmatically', () => {
      const nodes = makeExpandedTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      expect(component.isExpanded(nodes[0])).toBe(true);

      component.collapseNode(nodes[0]);
      fixture.detectChanges();

      expect(component.isExpanded(nodes[0])).toBe(false);
    });

    it('should toggle a node', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      component.toggleNode(nodes[0]);
      expect(component.isExpanded(nodes[0])).toBe(true);

      component.toggleNode(nodes[0]);
      expect(component.isExpanded(nodes[0])).toBe(false);
    });

    it('should expand all nodes', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      component.expandAll();
      fixture.detectChanges();

      expect(component.isExpanded(nodes[0])).toBe(true);
      expect(component.isExpanded(nodes[1])).toBe(true);
    });

    it('should collapse all nodes', () => {
      const nodes = makeExpandedTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      component.collapseAll();
      fixture.detectChanges();

      expect(component.isExpanded(nodes[0])).toBe(false);
    });

    it('should emit nodeExpand when expanding', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      let emittedNode: TreeNode | null = null;
      component.nodeExpand.subscribe((e) => (emittedNode = e.node));

      component.expandNode(nodes[0]);

      expect(emittedNode).toBe(nodes[0]);
    });

    it('should emit nodeCollapse when collapsing', () => {
      const nodes = makeExpandedTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      let emittedNode: TreeNode | null = null;
      component.nodeCollapse.subscribe((e) => (emittedNode = e.node));

      component.collapseNode(nodes[0]);

      expect(emittedNode).toBe(nodes[0]);
    });

    it('should expand all when config.expandAll is true', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { expandAll: true } as TreeConfig);
      fixture.detectChanges();

      expect(component.isExpanded(nodes[0])).toBe(true);
      expect(component.isExpanded(nodes[1])).toBe(true);
    });

    it('should toggle node via toggle button click in template', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      const toggleBtn = el.querySelector('.app-tree-node-toggle button') as HTMLButtonElement;
      expect(toggleBtn).toBeTruthy();

      toggleBtn.click();
      fixture.detectChanges();

      expect(component.isExpanded(nodes[0])).toBe(true);
      expect(el.textContent).toContain('Resume.pdf');
    });
  });

  // -------------------------------------------------------------------------
  // Selection — single
  // -------------------------------------------------------------------------

  describe('selection — single mode', () => {
    it('should select a node in single mode', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'single' } as TreeConfig);
      fixture.detectChanges();

      component.selectNode(nodes[2]); // README.md
      expect(component.isSelected(nodes[2])).toBe(true);
    });

    it('should replace selection when selecting another node', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'single' } as TreeConfig);
      fixture.detectChanges();

      component.selectNode(nodes[0]);
      expect(component.isSelected(nodes[0])).toBe(true);

      component.selectNode(nodes[1]);
      expect(component.isSelected(nodes[1])).toBe(true);
      expect(component.isSelected(nodes[0])).toBe(false);
    });

    it('should emit nodeSelect event', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'single' } as TreeConfig);
      fixture.detectChanges();

      let emittedNode: TreeNode | null = null;
      component.nodeSelect.subscribe((e) => (emittedNode = e.node));

      component.selectNode(nodes[0]);
      expect(emittedNode).toBe(nodes[0]);
    });

    it('should emit selectionChange with the selected node', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'single' } as TreeConfig);
      fixture.detectChanges();

      let emitted: TreeNode | TreeNode[] | null = null;
      component.selectionChange.subscribe((v) => (emitted = v));

      component.selectNode(nodes[0]);
      expect(emitted).toBe(nodes[0]);
    });

    it('should unselect a node', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'single' } as TreeConfig);
      fixture.detectChanges();

      component.selectNode(nodes[0]);
      expect(component.isSelected(nodes[0])).toBe(true);

      component.unselectNode(nodes[0]);
      expect(component.isSelected(nodes[0])).toBe(false);
    });

    it('should emit nodeUnselect event', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'single' } as TreeConfig);
      fixture.detectChanges();

      component.selectNode(nodes[0]);

      let emittedNode: TreeNode | null = null;
      component.nodeUnselect.subscribe((e) => (emittedNode = e.node));

      component.unselectNode(nodes[0]);
      expect(emittedNode).toBe(nodes[0]);
    });

    it('should not select when selectionMode is null', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: null } as TreeConfig);
      fixture.detectChanges();

      component.selectNode(nodes[0]);
      expect(component.isSelected(nodes[0])).toBe(false);
    });

    it('should not select when node.selectable is false', () => {
      const nodes: TreeNode[] = [{ key: 'a', label: 'A', selectable: false }];
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'single' } as TreeConfig);
      fixture.detectChanges();

      component.onNodeClick(new Event('click'), nodes[0]);
      expect(component.isSelected(nodes[0])).toBe(false);
    });
  });

  // -------------------------------------------------------------------------
  // Selection — multiple
  // -------------------------------------------------------------------------

  describe('selection — multiple mode', () => {
    it('should add to selection in multiple mode', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'multiple' } as TreeConfig);
      fixture.detectChanges();

      component.selectNode(nodes[0]);
      component.selectNode(nodes[1]);

      expect(component.isSelected(nodes[0])).toBe(true);
      expect(component.isSelected(nodes[1])).toBe(true);
    });

    it('should emit selectionChange with array of selected nodes', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'multiple' } as TreeConfig);
      fixture.detectChanges();

      let emitted: TreeNode | TreeNode[] | null = null;
      component.selectionChange.subscribe((v) => (emitted = v));

      component.selectNode(nodes[0]);
      component.selectNode(nodes[1]);

      expect(Array.isArray(emitted)).toBe(true);
      expect((emitted as unknown as TreeNode[]).length).toBe(2);
    });

    it('should toggle selection on click in multiple mode', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'multiple' } as TreeConfig);
      fixture.detectChanges();

      component.onNodeClick(new Event('click'), nodes[0]);
      expect(component.isSelected(nodes[0])).toBe(true);

      component.onNodeClick(new Event('click'), nodes[0]);
      expect(component.isSelected(nodes[0])).toBe(false);
    });
  });

  // -------------------------------------------------------------------------
  // Selection — checkbox
  // -------------------------------------------------------------------------

  describe('selection — checkbox mode', () => {
    it('should render checkboxes when selectionMode is checkbox', () => {
      const nodes = makeExpandedTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'checkbox' } as TreeConfig);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      const checkboxes = el.querySelectorAll('input[type="checkbox"]');
      expect(checkboxes.length).toBeGreaterThan(0);
    });

    it('should select node and propagate down to children', () => {
      const nodes = makeExpandedTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'checkbox' } as TreeConfig);
      fixture.detectChanges();

      // Select parent — should propagate to children
      component.selectNode(nodes[0]);
      fixture.detectChanges();

      expect(component.isSelected(nodes[0])).toBe(true);
      expect(component.isSelected(nodes[0].children![0])).toBe(true);
      expect(component.isSelected(nodes[0].children![1])).toBe(true);
    });

    it('should not propagate down when propagateSelectionDown is false', () => {
      const nodes = makeExpandedTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', {
        selectionMode: 'checkbox',
        propagateSelectionDown: false,
      } as TreeConfig);
      fixture.detectChanges();

      component.selectNode(nodes[0]);
      fixture.detectChanges();

      expect(component.isSelected(nodes[0])).toBe(true);
      expect(component.isSelected(nodes[0].children![0])).toBe(false);
    });

    it('should unselect node and propagate down', () => {
      const nodes = makeExpandedTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'checkbox' } as TreeConfig);
      fixture.detectChanges();

      // Select, then unselect
      component.selectNode(nodes[0]);
      fixture.detectChanges();
      component.selectNode(nodes[0]); // toggle off
      fixture.detectChanges();

      expect(component.isSelected(nodes[0])).toBe(false);
      expect(component.isSelected(nodes[0].children![0])).toBe(false);
      expect(component.isSelected(nodes[0].children![1])).toBe(false);
    });
  });

  // -------------------------------------------------------------------------
  // Clear selection
  // -------------------------------------------------------------------------

  describe('clearSelection', () => {
    it('should clear all selections', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'multiple' } as TreeConfig);
      fixture.detectChanges();

      component.selectNode(nodes[0]);
      component.selectNode(nodes[1]);
      expect(component.isSelected(nodes[0])).toBe(true);

      component.clearSelection();
      expect(component.isSelected(nodes[0])).toBe(false);
      expect(component.isSelected(nodes[1])).toBe(false);
    });
  });

  // -------------------------------------------------------------------------
  // Node state helpers
  // -------------------------------------------------------------------------

  describe('node state helpers', () => {
    it('hasChildren should return true for nodes with children', () => {
      const nodes = makeSimpleTree();
      fixture.detectChanges();
      expect(component.hasChildren(nodes[0])).toBe(true);
    });

    it('hasChildren should return true for lazy nodes (leaf=false)', () => {
      const lazyNode: TreeNode = { key: 'lazy', label: 'Lazy', leaf: false };
      fixture.detectChanges();
      expect(component.hasChildren(lazyNode)).toBe(true);
    });

    it('hasChildren should return false for leaf nodes', () => {
      const leafNode: TreeNode = { key: 'leaf', label: 'Leaf', leaf: true };
      fixture.detectChanges();
      expect(component.hasChildren(leafNode)).toBe(false);
    });

    it('getNodeKey should return the node key', () => {
      fixture.detectChanges();
      expect(component.getNodeKey({ key: 'abc', label: 'test' })).toBe('abc');
    });

    it('getNodeKey should return null when no key', () => {
      fixture.detectChanges();
      expect(component.getNodeKey({ label: 'test' })).toBeNull();
    });

    it('getIndentStyle should return padding-left based on level and indent size', () => {
      fixture.detectChanges();
      const style = component.getIndentStyle(2);
      expect(style['padding-left']).toBe('48px'); // 2 * 24 default
    });
  });

  // -------------------------------------------------------------------------
  // Lazy loading
  // -------------------------------------------------------------------------

  describe('lazy loading', () => {
    it('should emit lazyLoad event when expanding a lazy node', () => {
      const lazyNode: TreeNode = { key: 'lazy', label: 'Lazy Folder', leaf: false };
      fixture.componentRef.setInput('nodes', [lazyNode]);
      fixture.detectChanges();

      let emittedNode: TreeNode | null = null;
      component.lazyLoad.subscribe((e) => (emittedNode = e.node));

      component.expandNode(lazyNode);

      expect(emittedNode).toBe(lazyNode);
    });

    it('should mark node as loading during lazy load', () => {
      const lazyNode: TreeNode = { key: 'lazy', label: 'Lazy Folder', leaf: false };
      fixture.componentRef.setInput('nodes', [lazyNode]);
      fixture.detectChanges();

      component.expandNode(lazyNode);
      expect(component.isNodeLoading(lazyNode)).toBe(true);
    });

    it('should complete loading and expand the node', () => {
      const lazyNode: TreeNode = { key: 'lazy', label: 'Lazy Folder', leaf: false };
      fixture.componentRef.setInput('nodes', [lazyNode]);
      fixture.detectChanges();

      component.expandNode(lazyNode);
      expect(component.isNodeLoading(lazyNode)).toBe(true);

      // Simulate loading complete — add children and call completeLoading
      lazyNode.children = [{ key: 'child', label: 'Child', leaf: true }];
      component.completeLoading(lazyNode);

      expect(component.isNodeLoading(lazyNode)).toBe(false);
      expect(component.isExpanded(lazyNode)).toBe(true);
    });
  });

  // -------------------------------------------------------------------------
  // Filtering
  // -------------------------------------------------------------------------

  describe('filtering', () => {
    it('should show filter input when filterable is true', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { filterable: true } as TreeConfig);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      const filterInput = el.querySelector('.app-tree-filter input');
      expect(filterInput).toBeTruthy();
    });

    it('should not show filter input when filterable is false', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      const filterInput = el.querySelector('.app-tree-filter input');
      expect(filterInput).toBeNull();
    });

    it('should filter nodes by text (lenient mode — shows ancestors)', () => {
      // Use expandAll so all nodes are visible
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { filterable: true, expandAll: true } as TreeConfig);
      fixture.detectChanges();

      component.onFilterTextChange('Resume');
      fixture.detectChanges();

      // In lenient mode, Documents (ancestor) + Resume.pdf should be visible
      const flatNodes = component.flatNodes();
      const labels = flatNodes.map((fn) => fn.node.label);
      expect(labels).toContain('Resume.pdf');
      expect(labels).toContain('Documents');
      // Pictures should NOT be visible (no match)
      expect(labels).not.toContain('Pictures');
    });

    it('should emit filterChange when filter text changes', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { filterable: true } as TreeConfig);
      fixture.detectChanges();

      let emittedFilter = '';
      let emittedCount = -1;
      component.filterChange.subscribe((e) => {
        emittedFilter = e.filter;
        emittedCount = e.matchedNodeCount;
      });

      component.onFilterTextChange('Resume');

      expect(emittedFilter).toBe('resume');
      expect(emittedCount).toBe(1);
    });

    it('should clear filter and show all nodes', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { filterable: true, expandAll: true } as TreeConfig);
      fixture.detectChanges();

      component.onFilterTextChange('Resume');
      fixture.detectChanges();

      // Now clear
      component.onFilterTextChange('');
      fixture.detectChanges();

      const flatNodes = component.flatNodes();
      // All expanded nodes should be visible again
      expect(flatNodes.length).toBeGreaterThan(3);
    });
  });

  // -------------------------------------------------------------------------
  // Keyboard navigation
  // -------------------------------------------------------------------------

  describe('keyboard navigation', () => {
    function dispatchKey(key: string): void {
      const event = new KeyboardEvent('keydown', { key, bubbles: true });
      fixture.nativeElement.dispatchEvent(event);
    }

    it('should not respond to keyboard when keyboardNavigation is false', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { keyboardNavigation: false } as TreeConfig);
      fixture.detectChanges();

      dispatchKey('ArrowDown');
      fixture.detectChanges();

      // No node should be focused
      expect(component.isFocused(nodes[0])).toBe(false);
    });

    it('should focus first node on ArrowDown when nothing is focused', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { keyboardNavigation: true } as TreeConfig);
      fixture.detectChanges();

      dispatchKey('ArrowDown');
      fixture.detectChanges();

      expect(component.isFocused(nodes[0])).toBe(true);
    });

    it('should focus first node on Home key', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { keyboardNavigation: true } as TreeConfig);
      fixture.detectChanges();

      // First focus the second node
      dispatchKey('ArrowDown');
      dispatchKey('ArrowDown');
      fixture.detectChanges();

      dispatchKey('Home');
      fixture.detectChanges();

      expect(component.isFocused(nodes[0])).toBe(true);
    });

    it('should focus last node on End key', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { keyboardNavigation: true } as TreeConfig);
      fixture.detectChanges();

      dispatchKey('End');
      fixture.detectChanges();

      // Last visible root node
      expect(component.isFocused(nodes[nodes.length - 1])).toBe(true);
    });
  });

  // -------------------------------------------------------------------------
  // Drag and drop
  // -------------------------------------------------------------------------

  describe('drag and drop', () => {
    it('should not emit drag events when dragDrop is disabled', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { dragDrop: false } as TreeConfig);
      fixture.detectChanges();

      let emitted = false;
      component.nodeDragStart.subscribe(() => (emitted = true));

      const event = new DragEvent('dragstart');
      component.onDragStart(event, nodes[0]);

      expect(emitted).toBe(false);
    });

    it('should emit nodeDragStart when drag begins', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { dragDrop: true } as TreeConfig);
      fixture.detectChanges();

      let emittedNode: TreeNode | null = null;
      component.nodeDragStart.subscribe((e) => (emittedNode = e.node));

      const event = new DragEvent('dragstart');
      component.onDragStart(event, nodes[0]);

      expect(emittedNode).toBe(nodes[0]);
    });

    it('should emit nodeDragEnd when drag ends', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { dragDrop: true } as TreeConfig);
      fixture.detectChanges();

      let emittedNode: TreeNode | null = null;
      component.nodeDragEnd.subscribe((e) => (emittedNode = e.node));

      const startEvent = new DragEvent('dragstart');
      component.onDragStart(startEvent, nodes[0]);

      const endEvent = new DragEvent('dragend');
      component.onDragEnd(endEvent, nodes[0]);

      expect(emittedNode).toBe(nodes[0]);
    });

    it('should not start drag when node.draggable is false', () => {
      const nodes: TreeNode[] = [{ key: 'a', label: 'A', draggable: false }];
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { dragDrop: true } as TreeConfig);
      fixture.detectChanges();

      let emitted = false;
      component.nodeDragStart.subscribe(() => (emitted = true));

      const event = new DragEvent('dragstart');
      component.onDragStart(event, nodes[0]);

      expect(emitted).toBe(false);
    });

    it('should mark dragging state', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { dragDrop: true } as TreeConfig);
      fixture.detectChanges();

      const event = new DragEvent('dragstart');
      component.onDragStart(event, nodes[0]);

      expect(component.isDragging(nodes[0])).toBe(true);
      expect(component.isDragging(nodes[1])).toBe(false);
    });

    it('should emit nodeDrop when dropped', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { dragDrop: true } as TreeConfig);
      fixture.detectChanges();

      let dropData: { dragNode: TreeNode; dropNode: TreeNode } | null = null;
      component.nodeDrop.subscribe((e) => {
        dropData = { dragNode: e.dragNode, dropNode: e.dropNode! };
      });

      // Start drag on first node
      component.onDragStart(new DragEvent('dragstart'), nodes[0]);

      // Drop on second node
      component.onDrop(new DragEvent('drop'), nodes[1], 'inside');

      expect(dropData).toBeTruthy();
      expect(dropData!.dragNode).toBe(nodes[0]);
      expect(dropData!.dropNode).toBe(nodes[1]);
    });
  });

  // -------------------------------------------------------------------------
  // Selection input (two-way binding)
  // -------------------------------------------------------------------------

  describe('selection input', () => {
    it('should initialize selected state from selection input (single)', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'single' } as TreeConfig);
      fixture.componentRef.setInput('selection', nodes[0]);
      fixture.detectChanges();

      expect(component.isSelected(nodes[0])).toBe(true);
    });

    it('should initialize selected state from selection input (multiple)', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.componentRef.setInput('config', { selectionMode: 'multiple' } as TreeConfig);
      fixture.componentRef.setInput('selection', [nodes[0], nodes[1]]);
      fixture.detectChanges();

      expect(component.isSelected(nodes[0])).toBe(true);
      expect(component.isSelected(nodes[1])).toBe(true);
    });
  });

  // -------------------------------------------------------------------------
  // Config computed properties
  // -------------------------------------------------------------------------

  describe('config computed properties', () => {
    it('should expose selectionMode from config', () => {
      fixture.componentRef.setInput('config', { selectionMode: 'multiple' } as TreeConfig);
      fixture.detectChanges();
      expect(component.selectionMode()).toBe('multiple');
    });

    it('should expose isDragDropEnabled from config', () => {
      fixture.componentRef.setInput('config', { dragDrop: true } as TreeConfig);
      fixture.detectChanges();
      expect(component.isDragDropEnabled()).toBe(true);
    });

    it('should expose isFilterable from config', () => {
      fixture.componentRef.setInput('config', { filterable: true } as TreeConfig);
      fixture.detectChanges();
      expect(component.isFilterable()).toBe(true);
    });

    it('should expose showLines from config', () => {
      fixture.componentRef.setInput('config', { showLines: true } as TreeConfig);
      fixture.detectChanges();
      expect(component.showLines()).toBe(true);
    });

    it('should use default indentSize of 24', () => {
      fixture.detectChanges();
      expect(component.indentSize()).toBe(24);
    });

    it('should use custom indentSize from config', () => {
      fixture.componentRef.setInput('config', { indentSize: 32 } as TreeConfig);
      fixture.detectChanges();
      expect(component.indentSize()).toBe(32);
    });
  });

  // -------------------------------------------------------------------------
  // FlatNodes computation
  // -------------------------------------------------------------------------

  describe('flatNodes computed', () => {
    it('should produce flat nodes for root-level only when collapsed', () => {
      const nodes = makeSimpleTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      const flat = component.flatNodes();
      expect(flat).toHaveLength(3); // 3 root nodes, all collapsed
      expect(flat[0].level).toBe(0);
      expect(flat[0].node.label).toBe('Documents');
    });

    it('should include children when expanded', () => {
      const nodes = makeExpandedTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      const flat = component.flatNodes();
      expect(flat).toHaveLength(3); // Documents + 2 children
      expect(flat[1].level).toBe(1);
      expect(flat[1].parent).toBe(nodes[0]);
    });

    it('should set first/last flags correctly', () => {
      const nodes = makeExpandedTree();
      fixture.componentRef.setInput('nodes', nodes);
      fixture.detectChanges();

      const flat = component.flatNodes();
      // Root is first and last (only root)
      expect(flat[0].first).toBe(true);
      expect(flat[0].last).toBe(true);
      // First child
      expect(flat[1].first).toBe(true);
      expect(flat[1].last).toBe(false);
      // Last child
      expect(flat[2].first).toBe(false);
      expect(flat[2].last).toBe(true);
    });
  });
});
