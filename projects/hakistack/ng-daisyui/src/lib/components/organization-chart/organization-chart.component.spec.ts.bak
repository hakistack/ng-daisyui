import { ComponentFixture, TestBed } from '@angular/core/testing';

import { OrganizationChartComponent } from './organization-chart.component';
import { TreeNode } from '../../api/treenode';
import { OrgChartNodeColor, OrgChartOrientation } from './organization-chart.types';

// ---------------------------------------------------------------------------
// Test data factories
// ---------------------------------------------------------------------------

function makeSingleRoot(): TreeNode[] {
  return [
    {
      key: 'ceo',
      label: 'Alice (CEO)',
      expanded: true,
      children: [
        {
          key: 'cto',
          label: 'Bob (CTO)',
          expanded: true,
          children: [
            { key: 'dev1', label: 'Charlie (Dev)', leaf: true },
            { key: 'dev2', label: 'Diana (Dev)', leaf: true },
          ],
        },
        {
          key: 'cfo',
          label: 'Eve (CFO)',
          leaf: true,
        },
      ],
    },
  ];
}

function makeMultipleRoots(): TreeNode[] {
  return [
    { key: 'dept-a', label: 'Department A', leaf: true },
    { key: 'dept-b', label: 'Department B', leaf: true },
  ];
}

function makeCollapsibleTree(): TreeNode[] {
  return [
    {
      key: 'root',
      label: 'Root',
      expanded: true,
      children: [
        { key: 'child-1', label: 'Child 1', leaf: true },
        { key: 'child-2', label: 'Child 2', leaf: true },
      ],
    },
  ];
}

// ---------------------------------------------------------------------------
// Tests
// ---------------------------------------------------------------------------

describe('OrganizationChartComponent', () => {
  let component: OrganizationChartComponent;
  let fixture: ComponentFixture<OrganizationChartComponent>;

  beforeEach(async () => {
    await TestBed.configureTestingModule({
      imports: [OrganizationChartComponent],
    }).compileComponents();

    fixture = TestBed.createComponent(OrganizationChartComponent);
    component = fixture.componentInstance;
  });

  it('should create', () => {
    fixture.detectChanges();
    expect(component).toBeTruthy();
  });

  // -------------------------------------------------------------------------
  // Rendering
  // -------------------------------------------------------------------------

  describe('rendering', () => {
    it('should render root node labels', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      expect(el.textContent).toContain('Alice (CEO)');
    });

    it('should render children of expanded nodes', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      expect(el.textContent).toContain('Bob (CTO)');
      expect(el.textContent).toContain('Eve (CFO)');
    });

    it('should render deeply nested expanded nodes', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      expect(el.textContent).toContain('Charlie (Dev)');
      expect(el.textContent).toContain('Diana (Dev)');
    });

    it('should render multiple root nodes', () => {
      const nodes = makeMultipleRoots();
      fixture.componentRef.setInput('value', nodes);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      expect(el.textContent).toContain('Department A');
      expect(el.textContent).toContain('Department B');
    });

    it('should not render children of collapsed nodes', () => {
      const nodes: TreeNode[] = [
        {
          key: 'root',
          label: 'Root',
          expanded: false,
          children: [{ key: 'child', label: 'Hidden Child', leaf: true }],
        },
      ];
      fixture.componentRef.setInput('value', nodes);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      expect(el.textContent).toContain('Root');
      expect(el.textContent).not.toContain('Hidden Child');
    });
  });

  // -------------------------------------------------------------------------
  // Node helpers
  // -------------------------------------------------------------------------

  describe('node helpers', () => {
    it('hasChildren should return true for nodes with children', () => {
      fixture.detectChanges();
      const nodeWithChildren: TreeNode = {
        key: 'a',
        label: 'A',
        children: [{ key: 'b', label: 'B' }],
      };
      expect(component.hasChildren(nodeWithChildren)).toBe(true);
    });

    it('hasChildren should return false for leaf nodes', () => {
      fixture.detectChanges();
      const leafNode: TreeNode = { key: 'a', label: 'A', leaf: true };
      expect(component.hasChildren(leafNode)).toBe(false);
    });

    it('hasChildren should return false for nodes with empty children', () => {
      fixture.detectChanges();
      const emptyChildren: TreeNode = { key: 'a', label: 'A', children: [] };
      expect(component.hasChildren(emptyChildren)).toBe(false);
    });

    it('isExpanded should return true when node.expanded is true', () => {
      fixture.detectChanges();
      expect(component.isExpanded({ key: 'a', label: 'A', expanded: true })).toBe(true);
    });

    it('isExpanded should return false when node.expanded is false or undefined', () => {
      fixture.detectChanges();
      expect(component.isExpanded({ key: 'a', label: 'A', expanded: false })).toBe(false);
      expect(component.isExpanded({ key: 'b', label: 'B' })).toBe(false);
    });

    it('getNodeIcon should return icon when no expand/collapse icons set', () => {
      fixture.detectChanges();
      const n: TreeNode = { key: 'a', label: 'A', icon: 'User' };
      expect(component.getNodeIcon(n)).toBe('User');
    });

    it('getNodeIcon should return expandedIcon when node is expanded', () => {
      fixture.detectChanges();
      const n: TreeNode = {
        key: 'a',
        label: 'A',
        icon: 'Folder',
        expandedIcon: 'FolderOpen',
        expanded: true,
        children: [{ key: 'b', label: 'B' }],
      };
      expect(component.getNodeIcon(n)).toBe('FolderOpen');
    });

    it('getNodeIcon should return collapsedIcon when node is collapsed', () => {
      fixture.detectChanges();
      const n: TreeNode = {
        key: 'a',
        label: 'A',
        icon: 'Folder',
        collapsedIcon: 'FolderClosed',
        expanded: false,
        children: [{ key: 'b', label: 'B' }],
      };
      expect(component.getNodeIcon(n)).toBe('FolderClosed');
    });

    it('getNodeColor should return node type as color', () => {
      fixture.detectChanges();
      const n: TreeNode = { key: 'a', label: 'A', type: 'success' };
      expect(component.getNodeColor(n)).toBe('success');
    });

    it('getNodeColor should fall back to default nodeColor input', () => {
      fixture.componentRef.setInput('nodeColor', 'accent');
      fixture.detectChanges();
      const n: TreeNode = { key: 'a', label: 'A' };
      expect(component.getNodeColor(n)).toBe('accent');
    });

    it('getNodeStyle should return node style or empty object', () => {
      fixture.detectChanges();
      expect(component.getNodeStyle({ key: 'a', label: 'A' })).toEqual({});
      expect(component.getNodeStyle({ key: 'a', label: 'A', style: { color: 'red' } })).toEqual({ color: 'red' });
    });
  });

  // -------------------------------------------------------------------------
  // Selection — single mode
  // -------------------------------------------------------------------------

  describe('selection — single mode', () => {
    it('should select a node on click', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();

      const event = new Event('click');
      component.selectNode(event, nodes[0]);

      expect(component.isNodeSelected(nodes[0])).toBe(true);
    });

    it('should emit onNodeSelect', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();

      let emittedNode: TreeNode | null = null;
      component.onNodeSelect.subscribe((e) => (emittedNode = e.node));

      component.selectNode(new Event('click'), nodes[0]);
      expect(emittedNode).toBe(nodes[0]);
    });

    it('should emit selectionChange with selected node', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();

      let emitted: TreeNode | TreeNode[] | null = 'not-called' as unknown as null;
      component.selectionChange.subscribe((v) => (emitted = v));

      component.selectNode(new Event('click'), nodes[0]);
      expect(emitted).toBe(nodes[0]);
    });

    it('should unselect when clicking same node again', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();

      const event = new Event('click');
      component.selectNode(event, nodes[0]);
      expect(component.isNodeSelected(nodes[0])).toBe(true);

      component.selectNode(event, nodes[0]);
      expect(component.isNodeSelected(nodes[0])).toBe(false);
    });

    it('should emit onNodeUnselect when unselecting', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();

      component.selectNode(new Event('click'), nodes[0]);

      let emittedNode: TreeNode | null = null;
      component.onNodeUnselect.subscribe((e) => (emittedNode = e.node));

      component.selectNode(new Event('click'), nodes[0]);
      expect(emittedNode).toBe(nodes[0]);
    });

    it('should emit selectionChange with null when unselecting', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();

      component.selectNode(new Event('click'), nodes[0]);

      let emitted: TreeNode | TreeNode[] | null = 'not-called' as unknown as null;
      component.selectionChange.subscribe((v) => (emitted = v));

      component.selectNode(new Event('click'), nodes[0]);
      expect(emitted).toBeNull();
    });

    it('should replace selection when selecting a different node', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();

      component.selectNode(new Event('click'), nodes[0]);
      expect(component.isNodeSelected(nodes[0])).toBe(true);

      component.selectNode(new Event('click'), nodes[0].children![0]);
      expect(component.isNodeSelected(nodes[0].children![0])).toBe(true);
      expect(component.isNodeSelected(nodes[0])).toBe(false);
    });

    it('should not select when selectionMode is null', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', null);
      fixture.detectChanges();

      component.selectNode(new Event('click'), nodes[0]);
      expect(component.isNodeSelected(nodes[0])).toBe(false);
    });

    it('should not select when node.selectable is false', () => {
      const nodes: TreeNode[] = [{ key: 'a', label: 'A', selectable: false }];
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();

      component.selectNode(new Event('click'), nodes[0]);
      expect(component.isNodeSelected(nodes[0])).toBe(false);
    });
  });

  // -------------------------------------------------------------------------
  // Selection — multiple mode
  // -------------------------------------------------------------------------

  describe('selection — multiple mode', () => {
    it('should add multiple selections', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'multiple');
      fixture.detectChanges();

      component.selectNode(new Event('click'), nodes[0]);
      component.selectNode(new Event('click'), nodes[0].children![0]);

      expect(component.isNodeSelected(nodes[0])).toBe(true);
      expect(component.isNodeSelected(nodes[0].children![0])).toBe(true);
    });

    it('should remove from selection when clicking selected node', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'multiple');
      fixture.detectChanges();

      component.selectNode(new Event('click'), nodes[0]);
      component.selectNode(new Event('click'), nodes[0].children![0]);

      expect(component.isNodeSelected(nodes[0])).toBe(true);

      // Unselect first
      component.selectNode(new Event('click'), nodes[0]);
      expect(component.isNodeSelected(nodes[0])).toBe(false);
      expect(component.isNodeSelected(nodes[0].children![0])).toBe(true);
    });

    it('should emit selectionChange with array', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'multiple');
      fixture.detectChanges();

      let emitted: TreeNode | TreeNode[] | null = null;
      component.selectionChange.subscribe((v) => (emitted = v));

      component.selectNode(new Event('click'), nodes[0]);
      component.selectNode(new Event('click'), nodes[0].children![0]);

      expect(Array.isArray(emitted)).toBe(true);
      expect((emitted as unknown as TreeNode[]).length).toBe(2);
    });

    it('should emit null when all are unselected', () => {
      const nodes = makeMultipleRoots();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'multiple');
      fixture.detectChanges();

      component.selectNode(new Event('click'), nodes[0]);

      let emitted: TreeNode | TreeNode[] | null = 'pending' as unknown as null;
      component.selectionChange.subscribe((v) => (emitted = v));

      component.selectNode(new Event('click'), nodes[0]);
      expect(emitted).toBeNull();
    });
  });

  // -------------------------------------------------------------------------
  // Expand / Collapse
  // -------------------------------------------------------------------------

  describe('expand and collapse', () => {
    it('should toggle node expansion', () => {
      const nodes = makeCollapsibleTree();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('collapsible', true);
      fixture.detectChanges();

      expect(component.isExpanded(nodes[0])).toBe(true);

      component.toggleNode(new Event('click'), nodes[0]);

      expect(component.isExpanded(nodes[0])).toBe(false);
    });

    it('should emit onNodeCollapse when collapsing', () => {
      const nodes = makeCollapsibleTree();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('collapsible', true);
      fixture.detectChanges();

      let emittedNode: TreeNode | null = null;
      component.onNodeCollapse.subscribe((e) => (emittedNode = e.node));

      component.toggleNode(new Event('click'), nodes[0]);

      expect(emittedNode).toBe(nodes[0]);
    });

    it('should emit onNodeExpand when expanding', () => {
      const nodes = makeCollapsibleTree();
      nodes[0].expanded = false;
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('collapsible', true);
      fixture.detectChanges();

      let emittedNode: TreeNode | null = null;
      component.onNodeExpand.subscribe((e) => (emittedNode = e.node));

      component.toggleNode(new Event('click'), nodes[0]);

      expect(emittedNode).toBe(nodes[0]);
    });

    it('should not toggle when collapsible is false', () => {
      const nodes = makeCollapsibleTree();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('collapsible', false);
      fixture.detectChanges();

      expect(component.isExpanded(nodes[0])).toBe(true);

      component.toggleNode(new Event('click'), nodes[0]);

      // Should remain expanded since collapsible is false
      expect(component.isExpanded(nodes[0])).toBe(true);
    });

    it('should not toggle leaf nodes', () => {
      const leafNode: TreeNode = { key: 'leaf', label: 'Leaf', leaf: true };
      fixture.componentRef.setInput('value', [leafNode]);
      fixture.componentRef.setInput('collapsible', true);
      fixture.detectChanges();

      let emitted = false;
      component.onNodeExpand.subscribe(() => (emitted = true));
      component.onNodeCollapse.subscribe(() => (emitted = true));

      component.toggleNode(new Event('click'), leafNode);

      expect(emitted).toBe(false);
    });

    it('should show toggle button for nodes with children', () => {
      const nodes = makeCollapsibleTree();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('collapsible', true);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      const toggleButtons = el.querySelectorAll('button[aria-label="Toggle children"]');
      expect(toggleButtons.length).toBeGreaterThan(0);
    });

    it('should hide children when collapsed via toggle button', () => {
      const nodes = makeCollapsibleTree();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('collapsible', true);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      expect(el.textContent).toContain('Child 1');

      const toggleBtn = el.querySelector('button[aria-label="Toggle children"]') as HTMLButtonElement;
      toggleBtn.click();
      fixture.detectChanges();

      expect(el.textContent).not.toContain('Child 1');
    });
  });

  // -------------------------------------------------------------------------
  // Orientation
  // -------------------------------------------------------------------------

  describe('orientation', () => {
    it('should default to vertical orientation', () => {
      fixture.detectChanges();
      expect(component.orientation()).toBe('vertical');
    });

    it('should apply horizontal class when orientation is horizontal', () => {
      fixture.componentRef.setInput('orientation', 'horizontal' as OrgChartOrientation);
      fixture.detectChanges();

      expect(component.containerClasses()).toContain('org-chart-horizontal');
    });

    it('should not apply horizontal class for vertical orientation', () => {
      fixture.componentRef.setInput('orientation', 'vertical' as OrgChartOrientation);
      fixture.detectChanges();

      expect(component.containerClasses()).not.toContain('org-chart-horizontal');
    });
  });

  // -------------------------------------------------------------------------
  // Node classes
  // -------------------------------------------------------------------------

  describe('getNodeClasses', () => {
    it('should include base class', () => {
      fixture.detectChanges();
      const n: TreeNode = { key: 'a', label: 'A' };
      const classes = component.getNodeClasses(n, 0);
      expect(classes).toContain('org-chart-node');
    });

    it('should include color class from node type', () => {
      fixture.detectChanges();
      const n: TreeNode = { key: 'a', label: 'A', type: 'success' };
      const classes = component.getNodeClasses(n, 0);
      expect(classes).toContain('org-chart-node-success');
    });

    it('should include default color class when no type', () => {
      fixture.componentRef.setInput('nodeColor', 'accent' as OrgChartNodeColor);
      fixture.detectChanges();
      const n: TreeNode = { key: 'a', label: 'A' };
      const classes = component.getNodeClasses(n, 0);
      expect(classes).toContain('org-chart-node-accent');
    });

    it('should include selectable class when selectionMode is set', () => {
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();
      const n: TreeNode = { key: 'a', label: 'A' };
      const classes = component.getNodeClasses(n, 0);
      expect(classes).toContain('org-chart-node-selectable');
    });

    it('should not include selectable class when node.selectable is false', () => {
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();
      const n: TreeNode = { key: 'a', label: 'A', selectable: false };
      const classes = component.getNodeClasses(n, 0);
      expect(classes).not.toContain('org-chart-node-selectable');
    });

    it('should include selected class when node is selected', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();

      component.selectNode(new Event('click'), nodes[0]);
      const classes = component.getNodeClasses(nodes[0], 0);
      expect(classes).toContain('org-chart-node-selected');
    });

    it('should include level class', () => {
      fixture.detectChanges();
      const n: TreeNode = { key: 'a', label: 'A' };
      const classes = component.getNodeClasses(n, 2);
      expect(classes).toContain('org-chart-level-2');
    });

    it('should include loading class when node is loading', () => {
      fixture.detectChanges();
      const n: TreeNode = { key: 'a', label: 'A', loading: true };
      const classes = component.getNodeClasses(n, 0);
      expect(classes).toContain('org-chart-node-loading');
    });

    it('should include custom styleClass from node', () => {
      fixture.detectChanges();
      const n: TreeNode = { key: 'a', label: 'A', styleClass: 'my-class' };
      const classes = component.getNodeClasses(n, 0);
      expect(classes).toContain('my-class');
    });
  });

  // -------------------------------------------------------------------------
  // Container classes
  // -------------------------------------------------------------------------

  describe('containerClasses', () => {
    it('should include base org-chart class', () => {
      fixture.detectChanges();
      expect(component.containerClasses()).toContain('org-chart');
    });

    it('should include custom styleClass', () => {
      fixture.componentRef.setInput('styleClass', 'custom-class');
      fixture.detectChanges();
      expect(component.containerClasses()).toContain('custom-class');
    });
  });

  // -------------------------------------------------------------------------
  // Line style
  // -------------------------------------------------------------------------

  describe('lineStyle', () => {
    it('should return empty object when no lineColor', () => {
      fixture.detectChanges();
      expect(component.lineStyle()).toEqual({});
    });

    it('should return borderColor when lineColor is set', () => {
      fixture.componentRef.setInput('lineColor', '#ff0000');
      fixture.detectChanges();
      expect(component.lineStyle()).toEqual({ borderColor: '#ff0000' });
    });
  });

  // -------------------------------------------------------------------------
  // Template context
  // -------------------------------------------------------------------------

  describe('getTemplateContext', () => {
    it('should return proper context object', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();

      const ctx = component.getTemplateContext(nodes[0], 0);

      expect(ctx.$implicit).toBe(nodes[0]);
      expect(ctx.node).toBe(nodes[0]);
      expect(ctx.level).toBe(0);
      expect(ctx.selected).toBe(false);
      expect(ctx.expanded).toBe(true);
      expect(typeof ctx.toggle).toBe('function');
      expect(typeof ctx.select).toBe('function');
    });

    it('should reflect selected state in context', () => {
      const nodes = makeSingleRoot();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();

      component.selectNode(new Event('click'), nodes[0]);
      const ctx = component.getTemplateContext(nodes[0], 0);

      expect(ctx.selected).toBe(true);
    });
  });

  // -------------------------------------------------------------------------
  // TrackBy
  // -------------------------------------------------------------------------

  describe('trackByNode', () => {
    it('should return key when available', () => {
      fixture.detectChanges();
      const n: TreeNode = { key: 'my-key', label: 'Test' };
      expect(component.trackByNode(0, n)).toBe('my-key');
    });

    it('should fall back to label when no key', () => {
      fixture.detectChanges();
      const n: TreeNode = { label: 'Test' };
      expect(component.trackByNode(0, n)).toBe('Test');
    });
  });

  // -------------------------------------------------------------------------
  // Default inputs
  // -------------------------------------------------------------------------

  describe('default input values', () => {
    it('should default preserveSpace to true', () => {
      fixture.detectChanges();
      expect(component.preserveSpace()).toBe(true);
    });

    it('should default orientation to vertical', () => {
      fixture.detectChanges();
      expect(component.orientation()).toBe('vertical');
    });

    it('should default nodeColor to primary', () => {
      fixture.detectChanges();
      expect(component.nodeColor()).toBe('primary');
    });

    it('should default collapsible to true', () => {
      fixture.detectChanges();
      expect(component.collapsible()).toBe(true);
    });

    it('should default showLines to true', () => {
      fixture.detectChanges();
      expect(component.showLines()).toBe(true);
    });

    it('should default selectionMode to null', () => {
      fixture.detectChanges();
      expect(component.selectionMode()).toBeNull();
    });

    it('should default value to empty array', () => {
      fixture.detectChanges();
      expect(component.value()).toEqual([]);
    });
  });

  // -------------------------------------------------------------------------
  // DOM interaction
  // -------------------------------------------------------------------------

  describe('DOM interaction', () => {
    it('should select node when clicking card element', () => {
      const nodes = makeMultipleRoots();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      const cards = el.querySelectorAll('.card');
      expect(cards.length).toBe(2);

      (cards[0] as HTMLElement).click();
      fixture.detectChanges();

      expect(component.isNodeSelected(nodes[0])).toBe(true);
    });

    it('should show ring class on selected node', () => {
      const nodes = makeMultipleRoots();
      fixture.componentRef.setInput('value', nodes);
      fixture.componentRef.setInput('selectionMode', 'single');
      fixture.detectChanges();

      component.selectNode(new Event('click'), nodes[0]);
      fixture.detectChanges();

      const el: HTMLElement = fixture.nativeElement;
      const selectedCard = el.querySelector('.ring-2');
      expect(selectedCard).toBeTruthy();
    });
  });
});
