{
  "name": "@hakistack/ng-daisyui",
  "version": "0.3.0",
  "description": "Angular UI components built with DaisyUI and Tailwind CSS",
  "author": "Hakistack",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/hakistack/ng-daisyui.git"
  },
  "publishConfig": {
    "registry": "https://registry.hakistack.dev/"
  },
  "keywords": [
    "angular",
    "components",
    "daisyui",
    "tailwind",
    "ui-library",
    "forms",
    "table"
  ],
  "exports": {
    ".": {
      "types": "./types/hakistack-ng-daisyui.d.ts",
      "browser": "./fesm2022/hakistack-ng-daisyui.mjs",
      "esm2022": "./esm2022/hakistack-ng-daisyui.mjs",
      "esm": "./esm2022/hakistack-ng-daisyui.mjs",
      "style": "./styles.css",
      "default": "./fesm2022/hakistack-ng-daisyui.mjs"
    },
    "./styles": {
      "style": "./styles.css",
      "default": "./styles.css"
    },
    "./plugin": {
      "import": "./plugin.mjs",
      "require": "./plugin.cjs"
    },
    "./plugin.mjs": "./plugin.mjs",
    "./styles.css": "./styles.css",
    "./themes/daisyui-v4-plugin": {
      "import": "./themes/daisyui-v4-plugin.mjs",
      "require": "./themes/daisyui-v4-plugin.cjs"
    },
    "./themes/daisyui-v4-preset": "./themes/daisyui-v4-preset.cjs",
    "./themes/daisyui-v4.css": "./themes/daisyui-v4.css",
    "./themes/daisyui-v5.css": "./themes/daisyui-v5.css"
  },
  "style": "./styles.css",
  "schematics": "./schematics/collection.json",
  "ng-add": {
    "save": "dependencies"
  },
  "peerDependencies": {
    "@angular/aria": ">=21.0.0",
    "@angular/cdk": ">=21.0.0",
    "@angular/common": ">=21.0.0",
    "@angular/core": ">=21.0.0",
    "@angular/forms": ">=21.0.0",
    "@angular/router": ">=21.0.0",
    "@kenjiuno/msgreader": "^1.28.0",
    "daisyui": "^5.0.0",
    "docx-preview": "^0.3.7",
    "dompurify": "^3.4.8",
    "foliate-js": "^1.0.1",
    "heic2any": "^0.0.4",
    "postal-mime": "^2.7.4",
    "rxjs": ">=7.8.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/router": {
      "optional": true
    },
    "@kenjiuno/msgreader": {
      "optional": true
    },
    "docx-preview": {
      "optional": true
    },
    "dompurify": {
      "optional": true
    },
    "foliate-js": {
      "optional": true
    },
    "heic2any": {
      "optional": true
    },
    "postal-mime": {
      "optional": true
    }
  },
  "dependencies": {
    "@lucide/angular": "^1.7.0",
    "@tiptap/core": "^3.0.0",
    "@tiptap/extension-file-handler": "^3.0.0",
    "@tiptap/extension-image": "^3.0.0",
    "@tiptap/extension-link": "^3.0.0",
    "@tiptap/extension-placeholder": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "@tiptap/suggestion": "^3.0.0",
    "fuse.js": "^7.0.0",
    "libphonenumber-js": "^1.12.42",
    "motion": "^12.0.0",
    "tslib": "^2.3.0",
    "uuid": "^14.0.0"
  },
  "sideEffects": false
}
