{
  "name": "@hakistack/ng-daisyui",
  "version": "0.1.25",
  "description": "Angular UI components built with DaisyUI and Tailwind CSS",
  "author": "Hakistack",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/hakistack/ng-daisyui.git"
  },
  "publishConfig": {
    "registry": "https://hakistack-registry.fly.dev"
  },
  "keywords": [
    "angular",
    "components",
    "daisyui",
    "tailwind",
    "ui-library",
    "forms",
    "table"
  ],
  "exports": {
    ".": {
      "style": "./styles.css",
      "default": "./styles.css"
    },
    "./plugin": {
      "import": "./plugin.mjs",
      "require": "./plugin.cjs"
    },
    "./plugin.mjs": "./plugin.mjs",
    "./styles.css": "./styles.css"
  },
  "style": "./styles.css",
  "peerDependencies": {
    "@angular/common": ">=21.0.0",
    "@angular/core": ">=21.0.0",
    "@angular/forms": ">=21.0.0",
    "@angular/cdk": ">=21.0.0",
    "@angular/router": ">=21.0.0",
    "rxjs": ">=7.8.0",
    "tailwindcss": ">=4.0.0",
    "daisyui": ">=5.0.0",
    "lucide-angular": ">=0.500.0",
    "sweetalert2": ">=11.0.0",
    "fuse.js": ">=7.0.0",
    "motion": ">=12.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/router": {
      "optional": true
    }
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "uuid": "^13.0.0"
  },
  "sideEffects": false
}
